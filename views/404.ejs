<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>صفحه پیدا نشد - Page Not Found - 404</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 2;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
        }

        .error-container {
            max-width: 700px;
            text-align: center;
            padding: 4rem 3rem;
            background: var(--bg);
            border: 1px solid var(--border);
        }

        .error-code {
            font-size: 8rem;
            font-weight: 700;
            color: var(--accent);
            line-height: 1;
            margin-bottom: 1.5rem;
            letter-spacing: -4px;
        }

        /* ============================== */
        /* BILINGUAL CONTENT - Center Aligned */
        /* ============================== */
        .bilingual-text {
            margin: 1.5rem 0 2rem;
        }

        .bilingual-text .en {
            direction: ltr;
            text-align: center;
            display: block;
            font-size: 1.1rem;
            color: var(--text);
            margin-bottom: 0.2rem;
        }

        .bilingual-text .fa {
            direction: rtl;
            text-align: center;
            display: block;
            font-size: 1.1rem;
            color: var(--text-light);
            margin-bottom: 0.2rem;
        }

        /* ============================== */
        /* HEADING (bilingual) */
        /* ============================== */
        .bilingual-heading {
            margin: 1rem 0 1.5rem;
        }

        .bilingual-heading .en {
            direction: ltr;
            text-align: center;
            display: block;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--primary);
        }

        .bilingual-heading .fa {
            direction: rtl;
            text-align: center;
            display: block;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--primary);
        }

        /* ============================== */
        /* BUTTON */
        /* ============================== */
        .btn-home {
            display: inline-block;
            background: var(--primary);
            color: white;
            padding: 0.7rem 2.5rem;
            border-radius: 4px;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.95rem;
            text-decoration: none;
            transition: background .2s;
            margin-top: 1rem;
        }

        .btn-home:hover {
            background: var(--accent);
        }

        .btn-home .en {
            display: inline;
        }

        .btn-home .fa {
            display: inline;
        }

        .btn-home .divider {
            color: rgba(255,255,255,0.4);
            margin: 0 0.5rem;
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 600px) {
            body {
                padding: 1rem;
            }

            .error-container {
                padding: 2rem 1.2rem;
            }

            .error-code {
                font-size: 5rem;
            }

            .bilingual-heading .en,
            .bilingual-heading .fa {
                font-size: 1.3rem;
            }

            .bilingual-text .en,
            .bilingual-text .fa {
                font-size: 0.95rem;
            }

            .btn-home {
                font-size: 0.85rem;
                padding: 0.6rem 1.5rem;
            }
        }

        @media (max-width: 400px) {
            .error-code {
                font-size: 3.5rem;
            }

            .bilingual-heading .en,
            .bilingual-heading .fa {
                font-size: 1.1rem;
            }

            .bilingual-text .en,
            .bilingual-text .fa {
                font-size: 0.85rem;
            }
        }
    </style>
</head>

<body>

    <!-- ============================== -->
    <!-- ERROR CONTENT -->
    <!-- ============================== -->
    <div class="error-container">

        <!-- Error code -->
        <div class="error-code">404</div>

        <!-- ============================== -->
        <!-- BILINGUAL HEADING -->
        <!-- ============================== -->
        <div class="bilingual-heading">
            <span class="en">Page Not Found</span>
            <span class="fa">صفحه پیدا نشد</span>
        </div>

        <!-- ============================== -->
        <!-- BILINGUAL TEXT - PARAGRAPH 1 -->
        <!-- ============================== -->
        <div class="bilingual-text">
            <span class="en">Sorry, the page you were looking for could not be found.</span>
            <span class="fa">متأسفانه صفحه‌ای که به دنبال آن بودید پیدا نشد.</span>
        </div>
        
        <!-- ============================== -->
        <!-- RETURN BUTTON (bilingual) -->
        <!-- ============================== -->
        <a href="/index" class="btn-home">
            <span class="en">Back to Homepage</span>
            <span class="divider">|</span>
            <span class="fa">بازگشت به صفحه اصلی</span>
        </a>

    </div>

</body>
</html>