<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>ویرایش بلاگ</title>
</head>
<body>

    <h1>ویرایش بلاگ</h1>
    <p><a href="/admin/blogs">بازگشت به لیست بلاگ‌ها</a> | <a href="/admin/logout">خروج</a></p>

    <hr>

    <form action="/admin/blogs/edit/<%= blog.id %>" method="POST">
        <div>
            <label for="title">عنوان</label>
            <input type="text" id="title" name="title" value="<%= blog.title %>" required>
        </div>

        <br>

        <div>
            <label for="subtitle">زیرعنوان</label>
            <input type="text" id="subtitle" name="subtitle" value="<%= blog.subtitle || '' %>">
        </div>

        <br>

        <div>
            <label for="writer">نویسنده</label>
            <input type="text" id="writer" name="writer" value="<%= blog.writer || '' %>">
        </div>

        <br>

        <div>
            <label for="date">تاریخ</label>
            <input type="text" id="date" name="date" value="<%= blog.date || '' %>">
        </div>

        <br>

        <div>
            <label for="image">آدرس تصویر</label>
            <input type="text" id="image" name="image" value="<%= blog.image || '' %>">
        </div>

        <br>

        <div>
            <label for="text">متن بلاگ</label>
            <textarea id="text" name="text" rows="10"><%= blog.text || '' %></textarea>
        </div>

        <br>

        <button type="submit">ذخیره تغییرات</button>
        <a href="/admin/blogs">انصراف</a>
    </form>

</body>
</html>