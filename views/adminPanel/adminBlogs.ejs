<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت بلاگ‌ها</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminBlogs_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>مدیریت بلاگ‌ها</h1>
            <div class="links">
                <a href="/admin/panel">بازگشت به پنل</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ADD BUTTON -->
        <!-- ============================== -->
        <a href="/admin/blogs/add" class="add-btn">➕ افزودن بلاگ جدید</a>

        <!-- ============================== -->
        <!-- TABLE -->
        <!-- ============================== -->
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>عنوان</th>
                        <th>نویسنده</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (blogs && blogs.length > 0) { %>
                        <% blogs.forEach((blog, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= blog.title %></td>
                                <td><%= blog.writer || '-' %></td>
                                <td class="table-actions">
                                    <a href="/admin/blogs/edit/<%= blog.id %>">ویرایش</a>
                                    |
                                    <a href="/admin/blogs/delete/<%= blog.id %>" class="delete-link">حذف</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr class="empty-row">
                            <td colspan="4">هیچ بلاگی وجود ندارد</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

</body>
</html>
