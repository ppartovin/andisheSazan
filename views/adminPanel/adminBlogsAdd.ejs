<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>افزودن بلاگ جدید</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminBlogsAdd_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>افزودن بلاگ جدید</h1>
            <div class="links">
                <a href="/admin/blogs">بازگشت به لیست بلاگ‌ها</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ERROR MESSAGE -->
        <!-- ============================== -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <!-- ============================== -->
        <!-- FORM -->
        <!-- ============================== -->
        <form action="/admin/blogs/add" method="POST">

            <div class="form-group">
                <label for="title">عنوان</label>
                <input type="text" id="title" name="title" maxlength="200" placeholder="عنوان بلاگ را وارد کنید..." required>
            </div>

            <div class="form-group">
                <label for="subtitle">زیرعنوان</label>
                <input type="text" id="subtitle" name="subtitle" maxlength="500" placeholder="زیرعنوان بلاگ را وارد کنید...">
            </div>

            <div class="form-group">
                <label for="writer">نویسنده</label>
                <input type="text" id="writer" name="writer" maxlength="100" placeholder="نام نویسنده را وارد کنید...">
            </div>

            <div class="form-group">
                <label for="date">تاریخ</label>
                <input type="text" id="date" name="date" placeholder="مثال: 1404/01/15" maxlength="20">
            </div>

            <div class="form-group">
                <label for="image">آدرس تصویر</label>
                <input type="url" id="image" name="image" placeholder="https://example.com/image.jpg" maxlength="500">
            </div>

            <div class="form-group">
                <label for="text">متن بلاگ</label>
                <textarea id="text" name="text" rows="10" maxlength="50000" placeholder="متن بلاگ را وارد کنید..."></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">ذخیره</button>
                <a href="/admin/blogs" class="btn-cancel">انصراف</a>
            </div>

        </form>

    </div>

</body>
</html>
