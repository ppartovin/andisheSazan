<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت سوالات متداول</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN CONTAINER */
        /* ============================== */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* ============================== */
        /* HEADER */
        /* ============================== */
        .page-header {
            padding: 2rem 0 1rem;
            border-bottom: 2px solid var(--border);
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .page-header .links {
            font-size: 0.95rem;
            color: var(--text-light);
        }

        .page-header .links a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }

        .page-header .links a:hover {
            color: var(--primary);
        }

        /* ============================== */
        /* ADD BUTTON */
        /* ============================== */
        .add-btn {
            display: inline-block;
            background: var(--primary);
            color: #fff;
            padding: 0.5rem 1.5rem;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: background .2s;
            border-radius: 4px;
            margin-bottom: 1.5rem;
        }

        .add-btn:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* TABLE */
        /* ============================== */
        .table-wrap {
            overflow-x: auto;
            margin-bottom: 2rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
            background: var(--bg);
            border: 1px solid var(--border);
        }

        thead th {
            background: var(--bg-warm);
            padding: 0.8rem 1rem;
            text-align: right;
            font-weight: 600;
            color: var(--text);
            border-bottom: 2px solid var(--border);
            font-size: 0.85rem;
        }

        tbody td {
            padding: 0.8rem 1rem;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }

        tbody tr:hover td {
            background: var(--bg-warm);
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        .table-actions a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.85rem;
            transition: color .2s;
        }

        .table-actions a:hover {
            color: var(--primary);
        }

        .table-actions .delete-link {
            color: #dc2626;
        }

        .table-actions .delete-link:hover {
            color: #b91c1c;
        }

        .empty-row td {
            text-align: center;
            padding: 2rem;
            color: var(--text-light);
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 768px) {
            .container {
                padding: 0 1.2rem;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }

            .page-header h1 {
                font-size: 1.6rem;
            }

            table {
                font-size: 0.8rem;
            }

            thead th,
            tbody td {
                padding: 0.5rem 0.6rem;
            }

            .add-btn {
                padding: 0.4rem 1rem;
                font-size: 0.8rem;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 0 0.8rem;
            }

            .page-header h1 {
                font-size: 1.3rem;
            }

            table {
                font-size: 0.7rem;
            }

            thead th,
            tbody td {
                padding: 0.3rem 0.4rem;
            }
        }
    </style>
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>مدیریت سوالات متداول</h1>
            <div class="links">
                <a href="/admin/panel">بازگشت به پنل</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ADD BUTTON -->
        <!-- ============================== -->
        <a href="/admin/faq/add" class="add-btn">➕ افزودن سوال جدید</a>

        <!-- ============================== -->
        <!-- TABLE -->
        <!-- ============================== -->
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>سوال</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (faqs && faqs.length > 0) { %>
                        <% faqs.forEach((faq, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= faq.question %></td>
                                <td class="table-actions">
                                    <a href="/admin/faq/edit/<%= faq.id %>">ویرایش</a>
                                    |
                                    <a href="/admin/faq/delete/<%= faq.id %>" class="delete-link">حذف</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr class="empty-row">
                            <td colspan="3">هیچ سوالی وجود ندارد</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

</body>
</html>
