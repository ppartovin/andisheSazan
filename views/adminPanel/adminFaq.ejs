<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت سوالات متداول</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminFaq_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>مدیریت سوالات متداول</h1>
            <div class="links">
                <a href="/admin/panel">بازگشت به پنل</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ADD BUTTON -->
        <!-- ============================== -->
        <a href="/admin/faq/add" class="add-btn">➕ افزودن سوال جدید</a>

        <!-- ============================== -->
        <!-- TABLE -->
        <!-- ============================== -->
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>سوال</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (faqs && faqs.length > 0) { %>
                        <% faqs.forEach((faq, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= faq.question %></td>
                                <td class="table-actions">
                                    <a href="/admin/faq/edit/<%= faq.id %>">ویرایش</a>
                                    |
                                    <a href="/admin/faq/delete/<%= faq.id %>" class="delete-link">حذف</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr class="empty-row">
                            <td colspan="3">هیچ سوالی وجود ندارد</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

</body>
</html>
