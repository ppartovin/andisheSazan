<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>افزودن سوال جدید</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN CONTAINER */
        /* ============================== */
        .container {
            max-width: 700px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* ============================== */
        /* HEADER */
        /* ============================== */
        .page-header {
            padding: 2rem 0 1rem;
            border-bottom: 2px solid var(--border);
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .page-header .links {
            font-size: 0.95rem;
            color: var(--text-light);
        }

        .page-header .links a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }

        .page-header .links a:hover {
            color: var(--primary);
        }

        /* ============================== */
        /* ERROR MESSAGE */
        /* ============================== */
        .error-message {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #dc2626;
            padding: 0.7rem 1rem;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            border-radius: 0;
        }

        /* ============================== */
        /* FORM */
        /* ============================== */
        .form-group {
            margin-bottom: 1.2rem;
        }

        .form-group label {
            display: block;
            font-weight: 500;
            color: var(--text);
            font-size: 0.9rem;
            margin-bottom: 0.3rem;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 0.7rem 1rem;
            font-family: inherit;
            font-size: 0.95rem;
            background: var(--bg);
            border: 1px solid var(--border);
            color: var(--text);
            transition: border-color .2s;
            border-radius: 0;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--accent);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 100px;
        }

        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 0.5rem;
        }

        .btn-submit {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 0.7rem 2rem;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: background .2s;
            border-radius: 4px;
        }

        .btn-submit:hover {
            background: var(--accent);
        }

        .btn-cancel {
            background: transparent;
            color: var(--text-light);
            border: 1px solid var(--border);
            padding: 0.7rem 2rem;
            font-family: inherit;
            font-size: 0.95rem;
            font-weight: 500;
            text-decoration: none;
            transition: background .2s, color .2s;
            display: inline-block;
            text-align: center;
            border-radius: 4px;
        }

        .btn-cancel:hover {
            background: var(--bg-warm);
            color: var(--text);
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 768px) {
            .container {
                padding: 0 1.2rem;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }

            .page-header h1 {
                font-size: 1.6rem;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-submit,
            .btn-cancel {
                width: 100%;
                text-align: center;
                padding: 0.8rem;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 0 0.8rem;
            }

            .page-header h1 {
                font-size: 1.3rem;
            }

            .form-group input,
            .form-group textarea {
                padding: 0.5rem 0.7rem;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>افزودن سوال جدید</h1>
            <div class="links">
                <a href="/admin/faq">بازگشت به لیست سوالات</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ERROR MESSAGE -->
        <!-- ============================== -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <!-- ============================== -->
        <!-- FORM -->
        <!-- ============================== -->
        <form action="/admin/faq/add" method="POST">

            <div class="form-group">
                <label for="question">سوال</label>
                <input type="text" id="question" name="question" maxlength="500" placeholder="سوال خود را وارد کنید..." required>
            </div>

            <div class="form-group">
                <label for="answer">پاسخ</label>
                <textarea id="answer" name="answer" rows="5" maxlength="2000" placeholder="پاسخ سوال را وارد کنید..."></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">ذخیره</button>
                <a href="/admin/faq" class="btn-cancel">انصراف</a>
            </div>

        </form>

    </div>

</body>
</html>
