<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ویرایش سوال</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminFaqEdit_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>ویرایش سوال</h1>
            <div class="links">
                <a href="/admin/faq">بازگشت به لیست سوالات</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- FORM -->
        <!-- ============================== -->
        <form action="/admin/faq/edit/<%= faq.id %>" method="POST">

            <div class="form-group">
                <label for="question">سوال</label>
                <input type="text" id="question" name="question" value="<%= faq.question %>" maxlength="500" placeholder="سوال خود را وارد کنید..." required>
            </div>

            <div class="form-group">
                <label for="answer">پاسخ</label>
                <textarea id="answer" name="answer" rows="5" maxlength="2000" placeholder="پاسخ سوال را وارد کنید..."><%= faq.answer || '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">ذخیره تغییرات</button>
                <a href="/admin/faq" class="btn-cancel">انصراف</a>
            </div>

        </form>

    </div>

</body>
</html>
