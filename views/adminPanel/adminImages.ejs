<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت تصاویر</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <!-- ============================== -->
    <!-- SCRIPTS -->
    <!-- ============================== -->
    <script src="/public/adminImages.js" defer></script>

        <link rel="stylesheet" href="/public/css/adminImages_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>مدیریت تصاویر</h1>
            <div class="links">
                <a href="/admin/panel">بازگشت به پنل</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ADD BUTTON -->
        <!-- ============================== -->
        <a href="/admin/images/add" class="add-btn">➕ افزودن عکس</a>

        <!-- ============================== -->
        <!-- IMAGES GRID -->
        <!-- ============================== -->
        <% if (images && images.length > 0) { %>
            <div class="images-grid">
                <% images.forEach(img => { %>
                    <div class="image-card">
                        <img src="<%= img.link %>" alt="<%= img.name %>">
                        <div class="filename"><%= img.name %></div>
                        <a href="javascript:void(0)" class="filelink copy-link" data-link="<%= img.link %>"><%= img.link %></a>
                        <form action="/admin/images/delete/<%= encodeURIComponent(img.name) %>" method="POST">
                            <button type="submit" class="delete-btn">حذف</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-message">هیچ تصویری یافت نشد</div>
        <% } %>

    </div>

</body>
</html>