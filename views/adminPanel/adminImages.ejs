<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت تصاویر</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <!-- ============================== -->
    <!-- SCRIPTS -->
    <!-- ============================== -->
    <script src="/public/adminImages.js" defer></script>

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN CONTAINER */
        /* ============================== */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* ============================== */
        /* HEADER */
        /* ============================== */
        .page-header {
            padding: 2rem 0 1rem;
            border-bottom: 2px solid var(--border);
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .page-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }

        .page-header .links {
            font-size: 0.95rem;
            color: var(--text-light);
        }

        .page-header .links a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 500;
            transition: color .2s;
        }

        .page-header .links a:hover {
            color: var(--primary);
        }

        /* ============================== */
        /* ADD BUTTON */
        /* ============================== */
        .add-btn {
            display: inline-block;
            background: var(--primary);
            color: #fff;
            padding: 0.5rem 1.5rem;
            font-family: inherit;
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: background .2s;
            border-radius: 4px;
            margin-bottom: 1.5rem;
        }

        .add-btn:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* IMAGES GRID */
        /* ============================== */
        .images-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .image-card {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 1rem;
            transition: transform .2s, box-shadow .2s;
            text-align: center;
        }

        .image-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, .04);
        }

        .image-card img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            background: var(--bg-warm);
            border: 1px solid var(--border);
        }

        .image-card .filename {
            font-size: 0.85rem;
            color: var(--text);
            margin: 0.5rem 0 0.2rem;
            word-break: break-all;
        }

        .image-card .filelink {
            font-size: 0.75rem;
            color: var(--accent);
            word-break: break-all;
            display: block;
            margin-bottom: 0.5rem;
            text-decoration: none;
            transition: color .2s;
            cursor: pointer;
        }

        .image-card .filelink:hover {
            color: var(--primary);
        }

        .image-card .delete-btn {
            background: #dc2626;
            color: #fff;
            border: none;
            padding: 0.3rem 1rem;
            font-family: inherit;
            font-size: 0.8rem;
            cursor: pointer;
            transition: background .2s;
            border-radius: 4px;
        }

        .image-card .delete-btn:hover {
            background: #b91c1c;
        }

        .empty-message {
            text-align: center;
            padding: 3rem 0;
            color: var(--text-light);
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 768px) {
            .container {
                padding: 0 1.2rem;
            }

            .page-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }

            .page-header h1 {
                font-size: 1.6rem;
            }

            .images-grid {
                grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
                gap: 1rem;
            }

            .image-card img {
                height: 120px;
            }
        }

        @media (max-width: 480px) {
            .container {
                padding: 0 0.8rem;
            }

            .page-header h1 {
                font-size: 1.3rem;
            }

            .images-grid {
                grid-template-columns: 1fr 1fr;
                gap: 0.8rem;
            }

            .image-card {
                padding: 0.7rem;
            }

            .image-card img {
                height: 100px;
            }

            .image-card .filename {
                font-size: 0.7rem;
            }
        }
    </style>
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>مدیریت تصاویر</h1>
            <div class="links">
                <a href="/admin/panel">بازگشت به پنل</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ADD BUTTON -->
        <!-- ============================== -->
        <a href="/admin/images/add" class="add-btn">➕ افزودن عکس</a>

        <!-- ============================== -->
        <!-- IMAGES GRID -->
        <!-- ============================== -->
        <% if (images && images.length > 0) { %>
            <div class="images-grid">
                <% images.forEach(img => { %>
                    <div class="image-card">
                        <img src="<%= img.link %>" alt="<%= img.name %>">
                        <div class="filename"><%= img.name %></div>
                        <a href="javascript:void(0)" class="filelink copy-link" data-link="<%= img.link %>"><%= img.link %></a>
                        <form action="/admin/images/delete/<%= encodeURIComponent(img.name) %>" method="POST">
                            <button type="submit" class="delete-btn">حذف</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-message">هیچ تصویری یافت نشد</div>
        <% } %>

    </div>

</body>
</html>