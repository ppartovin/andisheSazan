<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>افزودن تصویر</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminImagesAdd_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>افزودن تصویر جدید</h1>
            <div class="links">
                <a href="/admin/images">بازگشت به لیست تصاویر</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ERROR MESSAGE -->
        <!-- ============================== -->
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <!-- ============================== -->
        <!-- FORM -->
        <!-- ============================== -->
        <form action="/admin/images/add" method="POST" enctype="multipart/form-data">

            <div class="form-group">
                <label for="name">نام تصویر</label>
                <input type="text" id="name" name="name" maxlength="50" pattern="[a-zA-Z0-9_]+" placeholder="مثلاً: banner_main" required>
            </div>

            <div class="form-group">
                <label for="image">انتخاب تصویر</label>
                <input type="file" id="image" name="image" accept="image/*" required>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">آپلود</button>
                <a href="/admin/images" class="btn-cancel">انصراف</a>
            </div>

        </form>

    </div>

</body>
</html>
