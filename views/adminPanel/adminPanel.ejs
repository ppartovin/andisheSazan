<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>پنل مدیریت</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminPanel_style.css">
</head>
<body>

    <!-- ============================== -->
    <!-- MAIN CONTAINER -->
    <!-- ============================== -->
    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="admin-header">
            <h1>ادمین پنل</h1>
            <div class="user-info">
                <%= username %> | <a href="/admin/logout">خروج از حساب</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- DASHBOARD GRID -->
        <!-- ============================== -->
        <div class="dashboard-grid">

            <!-- محصولات -->
            <div class="dashboard-card">
                <span class="icon">📦</span>
                <h2>محصولات</h2>
                <p>مدیریت محصولات فروشگاه</p>
                <a href="/admin/products">مدیریت محصولات</a>
            </div>

            <!-- بلاگ‌ها -->
            <div class="dashboard-card">
                <span class="icon">✍️</span>
                <h2>بلاگ‌ها</h2>
                <p>مدیریت مقالات بلاگ</p>
                <a href="/admin/blogs">مدیریت بلاگ‌ها</a>
            </div>

            <!-- سوالات متداول -->
            <div class="dashboard-card">
                <span class="icon">❓</span>
                <h2>سوالات متداول</h2>
                <p>مدیریت سوالات متداول</p>
                <a href="/admin/faq">مدیریت سوالات متداول</a>
            </div>

            <!-- تصاویر -->
            <div class="dashboard-card">
                <span class="icon">🖼️</span>
                <h2>تصاویر</h2>
                <p>مدیریت تصاویر سایت</p>
                <a href="/admin/images">مدیریت تصاویر</a>
            </div>

        </div>

    </div>

</body>
</html>
