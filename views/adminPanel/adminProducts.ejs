<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>مدیریت محصولات</title>
</head>
<body>

    <h1>مدیریت محصولات</h1>
    <p><a href="/admin/panel">بازگشت به پنل</a> | <a href="/admin/logout">خروج</a></p>

    <hr>

    <a href="/admin/products/add">➕ افزودن محصول جدید</a>

    <br><br>

    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>#</th>
                <th>عنوان</th>
                <th>قیمت</th>
                <th>کد یکتا</th>
                <th>ویترین</th>
                <th>عملیات</th>
            </tr>
        </thead>
        <tbody>
            <% if (products && products.length > 0) { %>
                <% products.forEach((product, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= product.title %></td>
                        <td><%= product.price || '-' %></td>
                        <td><%= product.unique_code || '-' %></td>
                        <td>
                            <% if (product.isShowcase) { %>
                                ⭐ <a href="/admin/products/toggle-showcase/<%= product.unique_code %>">حذف از ویترین</a>
                            <% } else { %>
                                <a href="/admin/products/toggle-showcase/<%= product.unique_code %>">➕ افزودن به ویترین</a>
                            <% } %>
                        </td>
                        <td>
                            <a href="/admin/products/edit/<%= product.id %>">ویرایش</a>
                            |
                            <a href="/admin/products/delete/<%= product.id %>" onclick="return confirm('حذف شود؟')">حذف</a>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="6">هیچ محصولی وجود ندارد</td>
                </tr>
            <% } %>
        </tbody>
    </table>

</body>
</html>