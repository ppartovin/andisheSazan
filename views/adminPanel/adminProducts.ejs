<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>مدیریت محصولات</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminProducts_style.css">
</head>
<body>

    <div class="container">

        <!-- ============================== -->
        <!-- HEADER -->
        <!-- ============================== -->
        <header class="page-header">
            <h1>مدیریت محصولات</h1>
            <div class="links">
                <a href="/admin/panel">بازگشت به پنل</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ============================== -->
        <!-- ADD BUTTON -->
        <!-- ============================== -->
        <a href="/admin/products/add" class="add-btn">➕ افزودن محصول جدید</a>

        <!-- ============================== -->
        <!-- TABLE -->
        <!-- ============================== -->
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>عنوان</th>
                        <th>قیمت</th>
                        <th>کد یکتا</th>
                        <th>ویترین</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (products && products.length > 0) { %>
                        <% products.forEach((product, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= product.title %></td>
                                <td><%= product.price || '-' %></td>
                                <td><%= product.unique_code || '-' %></td>
                                <td>
                                    <% if (product.isShowcase) { %>
                                        ⭐ <a href="/admin/products/toggle-showcase/<%= product.unique_code %>" class="showcase-link">حذف از ویترین</a>
                                    <% } else { %>
                                        <a href="/admin/products/toggle-showcase/<%= product.unique_code %>" class="showcase-link">➕ افزودن به ویترین</a>
                                    <% } %>
                                </td>
                                <td class="table-actions">
                                    <a href="/admin/products/edit/<%= product.id %>">ویرایش</a>
                                    |
                                    <a href="/admin/products/delete/<%= product.id %>" class="delete-link" onclick="return confirm('حذف شود؟')">حذف</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr class="empty-row">
                            <td colspan="6">هیچ محصولی وجود ندارد</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

</body>
</html>
