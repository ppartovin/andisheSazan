<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>افزودن محصول جدید</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

        <link rel="stylesheet" href="/public/css/adminProductsAdd_style.css">
</head>
<body>

    <div class="container">

        <!-- HEADER -->
        <header class="page-header">
            <h1>افزودن محصول جدید</h1>
            <div class="links">
                <a href="/admin/products">بازگشت به لیست محصولات</a> |
                <a href="/admin/logout">خروج</a>
            </div>
        </header>

        <!-- ERROR MESSAGE -->
        <% if (error) { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <!-- FORM -->
        <form action="/admin/products/add" method="POST" id="productForm">
            <div class="form-card">

                <!-- اطلاعات پایه -->
                <div class="form-group">
                    <label for="title">عنوان <span style="color:#dc2626;">*</span></label>
                    <input type="text" id="title" name="title" maxlength="200" placeholder="عنوان محصول را وارد کنید..." required>
                </div>

                <div class="form-group">
                    <label for="subtitle">زیرعنوان</label>
                    <input type="text" id="subtitle" name="subtitle" maxlength="500" placeholder="زیرعنوان محصول را وارد کنید...">
                </div>

                <div class="form-group">
                    <label for="price">قیمت</label>
                    <input type="text" id="price" name="price" maxlength="50" placeholder="مثال: ۱,۰۰۰,۰۰۰ تومان">
                </div>

                <div class="form-group">
                    <label for="description">توضیحات</label>
                    <textarea id="description" name="description" rows="5" maxlength="5000" placeholder="توضیحات محصول را وارد کنید..."></textarea>
                </div>

                <!-- ============================== -->
                <!-- تصاویر (داینامیک) -->
                <!-- ============================== -->
                <div class="section-title">🖼️ تصاویر</div>
                <div id="images-container">
                    <div class="dynamic-group image-item">
                        <div class="form-group">
                            <label>آدرس تصویر</label>
                            <input type="url" name="image[]" placeholder="https://example.com/image.jpg">
                        </div>
                        <button type="button" class="remove-btn" data-container="images-container">حذف تصویر</button>
                    </div>
                </div>
                <button type="button" class="add-btn" id="addImageBtn">➕ افزودن تصویر</button>

                <!-- ============================== -->
                <!-- فروشگاه‌ها (داینامیک) -->
                <!-- ============================== -->
                <div class="section-title" style="margin-top:2rem;">🏪 فروشگاه‌ها</div>
                <div id="shops-container">
                    <div class="dynamic-group shop-item">
                        <div class="form-group">
                            <label>نام فروشگاه</label>
                            <input type="text" name="shop_name[]" placeholder="مثال: دیجیکالا">
                        </div>
                        <div class="form-group">
                            <label>لینک فروشگاه</label>
                            <input type="url" name="shop_link[]" placeholder="https://example.com">
                        </div>
                        <div class="form-group">
                            <label>آدرس تصویر فروشگاه</label>
                            <input type="url" name="shop_image[]" placeholder="https://example.com/logo.png">
                        </div>
                        <button type="button" class="remove-btn" data-container="shops-container">حذف فروشگاه</button>
                    </div>
                </div>
                <button type="button" class="add-btn" id="addShopBtn">➕ افزودن فروشگاه</button>

                <!-- ============================== -->
                <!-- ویژگی‌ها (داینامیک) -->
                <!-- ============================== -->
                <div class="section-title" style="margin-top:2rem;">📋 ویژگی‌ها</div>
                <div id="properties-container">
                    <div class="dynamic-group property-item">
                        <div class="form-group">
                            <label>عنوان ویژگی</label>
                            <input type="text" name="prop_key[]" placeholder="مثال: زمان بازی">
                        </div>
                        <div class="form-group">
                            <label>مقدار ویژگی</label>
                            <input type="text" name="prop_value[]" placeholder="مثال: 15 دقیقه">
                        </div>
                        <button type="button" class="remove-btn" data-container="properties-container">حذف ویژگی</button>
                    </div>
                </div>
                <button type="button" class="add-btn" id="addPropertyBtn">➕ افزودن ویژگی</button>

                <!-- دکمه‌ها -->
                <div class="form-actions" style="margin-top:2rem;">
                    <button type="submit" class="btn-submit">ذخیره</button>
                    <a href="/admin/products" class="btn-cancel">انصراف</a>
                </div>

            </div>
        </form>

    </div>

    <script src="/public/adminProductsAdd.js" defer></script>

</body>
</html>
