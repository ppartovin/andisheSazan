<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.title %></title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* BLOG HEADER */
        /* ============================== */
        header {
            padding: 2rem 5rem 1.5rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 2rem;
            background: var(--bg);
        }

        header h1 {
            font-size: 2.5rem;
            font-weight: 600;
            color: var(--primary);
            line-height: 1.3;
            margin-bottom: 0.5rem;
            letter-spacing: -1px;
        }

        .blog-meta {
            display: flex;
            gap: 2rem;
            font-size: 0.9rem;
            color: var(--text-light);
        }

        .blog-meta span {
            background: var(--bg-warm);
            padding: 0.2rem 0.8rem;
            border: 1px solid var(--border);
        }

        /* ============================== */
        /* MAIN */
        /* ============================== */
        main {
            padding: 0 5rem;
            max-width: 850px;
            margin: 0 auto;
        }

        /* ============================== */
        /* BLOG COVER */
        /* ============================== */
        .blog-cover {
            margin-bottom: 2.5rem;
        }

        .blog-cover img {
            width: 100%;
            height: auto;
            max-height: 450px;
            object-fit: cover;
            border: 1px solid var(--border);
            background: var(--bg-warm);
        }

        /* ============================== */
        /* BLOG CONTENT */
        /* ============================== */
        .blog-content p {
            font-size: 1.05rem;
            color: var(--text);
            line-height: 2;
            margin-bottom: 1.5rem;
            text-align: justify;
        }

        .blog-content p:last-child {
            margin-bottom: 4rem;
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 768px) {
            header {
                padding: 1.5rem 2rem;
            }

            header h1 {
                font-size: 2rem;
            }

            main {
                padding: 0 2rem;
            }

            .blog-meta {
                flex-direction: column;
                gap: 0.5rem;
            }

            .blog-content p {
                font-size: 0.95rem;
                line-height: 1.9;
            }
        }

        @media (max-width: 480px) {
            header {
                padding: 1rem 1.2rem;
            }

            header h1 {
                font-size: 1.5rem;
            }

            main {
                padding: 0 1.2rem;
            }

            .blog-meta {
                font-size: 0.8rem;
            }

            .blog-content p {
                font-size: 0.9rem;
                line-height: 1.8;
            }

            .blog-cover img {
                max-height: 250px;
            }
        }
    </style>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerEn.ejs') %>

    <!-- ============================== -->
    <!-- BLOG HEADER -->
    <!-- ============================== -->
    <header>
        <h1><%= data.title %></h1>

        <div class="blog-meta">
            <span>Author: <%= data.writer %></span>
            <span>Date: <%= data.date %></span>
        </div>
    </header>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- ============================== -->
        <!-- SECTION: Blog Cover Image -->
        <!-- ============================== -->
        <section class="blog-cover">
            <img src="<%= data.image %>" alt="<%= data.title %>">
        </section>

        <!-- ============================== -->
        <!-- SECTION: Blog Content -->
        <!-- ============================== -->
        <article class="blog-content">
            <% 
                const paragraphs = data.text.split('\n');
                paragraphs.forEach(p => { 
                    if(p.trim() !== '') {
            %>
                        <p><%= p %></p>
            <% 
                    }
                }); 
            %>
        </article>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footerEn.ejs') %>

</body>
</html>