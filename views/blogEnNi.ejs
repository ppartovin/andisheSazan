<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.title %></title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <link rel="stylesheet" href="/public/css/blogEnNi_style.css">
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerEnNi.ejs') %>

    <!-- ============================== -->
    <!-- BLOG HEADER -->
    <!-- ============================== -->
    <header>
        <h1><%= data.title %></h1>

        <div class="blog-meta">
            <span>Author: <%= data.writer %></span>
            <span>Date: <%= data.date %></span>
        </div>
    </header>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- ============================== -->
        <!-- SECTION: Blog Cover Image -->
        <!-- ============================== -->
        <section class="blog-cover">
            <img src="<%= data.image %>" alt="<%= data.title %>">
        </section>

        <!-- ============================== -->
        <!-- SECTION: Blog Content -->
        <!-- ============================== -->
        <article class="blog-content">
            <% 
                const paragraphs = data.text.split('\n');
                paragraphs.forEach(p => { 
                    if(p.trim() !== '') {
            %>
                        <p><%= p %></p>
            <% 
                    }
                }); 
            %>
        </article>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footerEnNi.ejs') %>

</body>
</html>