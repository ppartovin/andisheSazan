<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<title><%= data.title %></title>
</head>

<body>

<%- include('./partials/header.ejs') %>

<header>
  <h1><%= data.title %></h1>

  <div class="blog-meta">
    <span>نویسنده: <%= data.writer %></span>
    <span>تاریخ: <%= data.date %></span>
  </div>
</header>

<main>

<section class="blog-cover">
  <img src="<%= data.image %>" alt="<%= data.title %>">
</section>

<article class="blog-content">

  <% 
    // تبدیل متن چندخطی به پاراگراف
    const paragraphs = data.text.split('\n');
    paragraphs.forEach(p => { 
      if(p.trim() !== '') {
  %>

        <p><%= p %></p>

  <% 
      }
    }); 
  %>

</article>

</main>

<%- include('./partials/footer.ejs') %>

</body>
</html>
