<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>بلاگ</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700&display=swap');

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN */
        /* ============================== */
        main {
            padding: 0 5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ============================== */
        /* BLOG HEADER */
        /* ============================== */
        .blog-header {
            margin-top: 3rem;
            margin-bottom: 2.5rem;
        }

        .blog-header h1 {
            font-size: 2.8rem;
            font-weight: 600;
            color: var(--primary);
            letter-spacing: -1px;
            margin-bottom: 1rem;
        }

        .blog-search {
            display: flex;
            gap: 0.5rem;
            max-width: 450px;
        }

        .blog-search input {
            flex: 1;
            padding: 0.7rem 1rem;
            font-family: inherit;
            font-size: 0.95rem;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            transition: border-color .2s;
        }

        .blog-search input:focus {
            outline: none;
            border-color: var(--accent);
        }

        .blog-search button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.7rem 1.8rem;
            border-radius: 0;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background .2s;
        }

        .blog-search button:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* LATEST POSTS */
        /* ============================== */
        .latest-posts h2 {
            font-size: 2rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.5rem;
        }

        .posts {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .post {
            border: 1px solid var(--border);
            overflow: hidden;
            background: var(--bg);
            transition: transform .2s, box-shadow .2s;
            padding: 1rem;
        }

        .post:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, .04);
        }

        .post img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: var(--bg-warm);
            border-bottom: 1px solid var(--border);
            margin-bottom: 0.8rem;
        }

        .post h3 {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.3rem;
        }

        .post p {
            font-size: 0.9rem;
            color: var(--text-light);
            margin-bottom: 0.5rem;
        }

        .post span {
            display: block;
            font-size: 0.8rem;
            color: var(--text-light);
            margin-bottom: 0.8rem;
        }

        .post a {
            display: inline-block;
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.4rem 1.2rem;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            cursor: pointer;
            transition: background .2s;
        }

        .post a:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* SCROLL LOADER */
        /* ============================== */
        #scroll-loader {
            text-align: center;
            padding: 2rem 0;
            color: var(--text-light);
            font-size: 0.95rem;
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 992px) {
            main {
                padding: 0 2rem;
            }

            .blog-header h1 {
                font-size: 2.2rem;
            }

            .posts {
                grid-template-columns: repeat(2, 1fr);
                gap: 1.5rem;
            }
        }

        @media (max-width: 600px) {
            main {
                padding: 0 1.2rem;
            }

            .blog-header h1 {
                font-size: 1.8rem;
                margin-top: 2rem;
            }

            .blog-search {
                flex-direction: column;
                max-width: 100%;
            }

            .blog-search button {
                width: 100%;
                padding: 0.8rem;
            }

            .posts {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .post img {
                height: 150px;
            }
        }
    </style>
</head>

<body>

    <%- include('./partials/header.ejs') %>

    <main>

        <section class="blog-header">
            <h1>بلاگ</h1>

            <div class="blog-search">
                <input type="text" id="searchInput" placeholder="جستجو در مقالات">
                <button id="searchBtn">جستجو</button>
            </div>
        </section>

        <section class="latest-posts">
            <h2>مقالات</h2>
            <div class="posts" id="posts-container"></div>
            <div id="scroll-loader">در حال بارگذاری...</div>
        </section>

    </main>

    <%- include('./partials/footer.ejs') %>

    <script src="/public/blogs_Script.js" defer></script>

</body>
</html>