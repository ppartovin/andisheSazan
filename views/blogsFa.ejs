<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>بلاگ</title>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/header.ejs') %>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- ============================== -->
        <!-- SECTION: Blog Header & Search -->
        <!-- ============================== -->
        <section class="blog-header">
            <h1>بلاگ</h1>

            <div class="blog-search">
                <input type="text" placeholder="جستجو در مقالات">
                <button>جستجو</button>
            </div>
        </section>

        <!-- ============================== -->
        <!-- SECTION: Latest Posts -->
        <!-- ============================== -->
        <section class="latest-posts">
            <h2>مقالات</h2>

            <div class="posts" id="posts-container">
                <!-- Posts will be injected here -->
            </div>

            <div id="scroll-loader">
                در حال بارگذاری...
            </div>
        </section>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footer.ejs') %>

    <!-- ============================== -->
    <!-- SCRIPTS -->
    <!-- ============================== -->
    <script src="/public/blogs_Script.js" defer></script>

</body>
</html>