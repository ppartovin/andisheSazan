<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Custom Product Order</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN */
        /* ============================== */
        main {
            padding: 0 5rem;
            max-width: 1000px;
            margin: 0 auto;
        }

        main h1 {
            font-size: 2.8rem;
            font-weight: 600;
            color: var(--primary);
            line-height: 1.2;
            margin-top: 4rem;
            margin-bottom: 1rem;
            letter-spacing: -1px;
        }

        main>p {
            font-size: 1.1rem;
            color: var(--text-light);
            max-width: 700px;
            margin-bottom: 3rem;
        }

        /* ============================== */
        /* SECTION */
        /* ============================== */
        section {
            margin-bottom: 3.5rem;
        }

        section h2 {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.8rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.3rem;
        }

        section h1 {
            font-size: 2.2rem;
            font-weight: 600;
            color: var(--primary);
            margin-top: 2rem;
            margin-bottom: 1rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.3rem;
        }

        section p {
            font-size: 1.05rem;
            color: var(--text-light);
            margin-bottom: 1rem;
        }

        /* ============================== */
        /* LISTS */
        /* ============================== */
        ul,
        ol {
            list-style: none;
            padding: 0;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin: 1rem 0;
        }

        ul li,
        ol li {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 1rem 1.5rem;
            font-size: 0.95rem;
            color: var(--text);
            transition: transform .2s, box-shadow .2s;
        }

        ul li:hover,
        ol li:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, .04);
        }

        ul li strong {
            color: var(--primary);
        }

        ol {
            counter-reset: item;
        }

        ol li::before {
            counter-increment: item;
            content: counter(item) ". ";
            font-weight: 600;
            color: var(--accent);
            margin-right: 0.3rem;
        }

        /* ============================== */
        /* CONTACT INFO */
        /* ============================== */
        .contact-info {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-top: 0.5rem;
        }

        .contact-item {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 1.5rem 1.5rem;
            text-align: center;
            transition: transform .2s, box-shadow .2s;
        }

        .contact-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, .04);
        }

        .contact-item strong {
            display: block;
            color: var(--primary);
            font-weight: 600;
            font-size: 0.95rem;
            margin-bottom: 0.3rem;
        }

        .contact-item span {
            color: var(--text-light);
            font-size: 1.05rem;
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 992px) {
            main {
                padding: 0 2rem;
            }

            main h1 {
                font-size: 2.2rem;
                margin-top: 3rem;
            }

            ul,
            ol {
                grid-template-columns: 1fr;
            }

            .contact-info {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 600px) {
            main {
                padding: 0 1.2rem;
            }

            main h1 {
                font-size: 1.8rem;
                margin-top: 2rem;
            }

            main>p {
                font-size: 1rem;
            }

            section h2 {
                font-size: 1.4rem;
            }

            section h1 {
                font-size: 1.6rem;
            }

            ul li,
            ol li {
                padding: 0.8rem 1rem;
                font-size: 0.9rem;
            }

            .contact-info {
                grid-template-columns: 1fr;
            }

            .contact-item {
                padding: 1rem 1rem;
            }
        }
    </style>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerEn.ejs') %>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- Page title -->
        <h1>Custom Product Design & Production</h1>

        <!-- Introduction paragraph -->
        <p>
            If you are looking for a product with specific features, different dimensions, or a unique design, our technical team is ready to guide your idea from design to production.
        </p>

        <!-- ============================== -->
        <!-- SECTION 1: Customization Capabilities -->
        <!-- ============================== -->
        <section>
            <h2>Customization Capabilities</h2>

            <p>We can customize the following based on your needs:</p>

            <ul>
                <li><strong>Dimensions & Size:</strong> Production in non-standard sizes</li>
                <li><strong>Materials:</strong> Selection from our available material list</li>
                <li><strong>Color & Finish:</strong> Custom colors or corporate color codes</li>
                <li><strong>Engraving & Branding:</strong> Adding your logo or brand name on the product body</li>
            </ul>
        </section>

        <!-- ============================== -->
        <!-- SECTION 2: Project Execution Steps -->
        <!-- ============================== -->
        <section>
            <h2>Custom Project Execution Steps</h2>

            <ol>
                <li><strong>Initial Consultation:</strong> Needs assessment and feasibility study</li>
                <li><strong>Design & Approval:</strong> Sending initial designs or virtual mockups</li>
                <li><strong>Prototype Production:</strong> Creating a test version for quality and dimension verification</li>
                <li><strong>Mass Production:</strong> Starting the manufacturing process after your final approval</li>
            </ol>
        </section>

        <!-- ============================== -->
        <!-- SECTION 3: Contact Information -->
        <!-- ============================== -->
        <section>
            <h1>Contact Us</h1>

            <div class="contact-info">
                <div class="contact-item">
                    <strong>Email</strong>
                    <span>info@example.com</span>
                </div>

                <div class="contact-item">
                    <strong>Phone</strong>
                    <span>+98 900 000 0000</span>
                </div>

                <div class="contact-item">
                    <strong>Address</strong>
                    <span>Tehran, Iran</span>
                </div>
            </div>
        </section>

        <!-- ============================== -->
        <!-- SECTION 4: Sample Projects -->
        <!-- ============================== -->
        <section>
            <h2>Sample Projects</h2>

            <p>This section displays a list or categorization of previous custom projects.</p>

            <ul>
                <li>Custom Project #1</li>
                <li>Custom Project #2</li>
                <li>Custom Project #3</li>
            </ul>
        </section>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footerEn.ejs') %>

</body>
</html>