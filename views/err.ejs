<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطای سرور / Server Error</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <link rel="stylesheet" href="/public/css/err_style.css">
</head>

<body>

    <!-- ============================== -->
    <!-- ERROR CONTENT -->
    <!-- ============================== -->
    <div class="error-container">
        <span class="error-icon">⚠️</span>

        <!-- ============================== -->
        <!-- BILINGUAL HEADING -->
        <!-- ============================== -->
        <div class="bilingual-heading">
            <span class="en">Internal Server Error</span>
            <span class="fa">خطای داخلی سرور</span>
        </div>

        <!-- ============================== -->
        <!-- BILINGUAL TEXT -->
        <!-- ============================== -->
        <div class="bilingual-text">
            <span class="en">Something went wrong on our end. Please try again later.</span>
            <span class="fa">در حال حاضر مشکلی در سیستم رخ داده است، لطفاً بعداً تلاش کنید.</span>
        </div>

        <!-- ============================== -->
        <!-- RETURN BUTTON (bilingual) -->
        <!-- ============================== -->
        <a href="/index" class="btn-home">
            <span class="en">Back to Homepage</span>
            <span class="divider">|</span>
            <span class="fa">بازگشت به صفحه اصلی</span>
        </a>
    </div>

</body>
</html>