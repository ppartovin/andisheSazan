<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Frequently Asked Questions</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <link rel="stylesheet" href="/public/css/faqEnNi_style.css">

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
    <script src="/public/faq_Script.js" defer></script>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerEnNi.ejs') %>

        <!-- ============================== -->
        <!-- MAIN CONTENT -->
        <!-- ============================== -->
        <main>

            <!-- ============================== -->
            <!-- SECTION: FAQ Search -->
            <!-- ============================== -->
            <section class="faq-search">
                <input type="text" placeholder="Search questions">
                <button>Search</button>
            </section>

            <!-- ============================== -->
            <!-- SECTION: FAQ List -->
            <!-- ============================== -->
            <section class="faq">
                <h2>Frequently Asked Questions</h2>

                <div class="faq-list">
                    <% if (data && Object.keys(data).length> 0) { %>
                        <% Object.values(data).forEach(item=> { %>
                            <div class="faq-item">
                                <div class="faq-title">
                                    <%= item.question %>
                                </div>
                                <div class="faq-content">
                                    <%= item.answer %>
                                </div>
                            </div>
                        <% }) %>
                        <% } else { %>
                            <p>No questions found.</p>
                        <% } %>
                </div>
            </section>

        </main>

        <!-- ============================== -->
        <!-- FOOTER: Include footer partial -->
        <!-- ============================== -->
        <%- include('./partials/footerEnNi.ejs') %>

</body>

</html>