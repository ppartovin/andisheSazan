<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سوالات متداول</title>

    <!-- ============================== -->
    <!-- STYLES -->
    <!-- ============================== -->
    <style>
        .faq-search {
            margin-bottom: 30px;
        }

        .faq-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .faq-item {
            border: 1px solid #ccc;
            padding: 15px;
        }

        .faq-title {
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
        }

        .faq-content {
            font-size: 16px;
            margin-top: 10px;
        }
    </style>

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
    <script src="/public/faq_Script.js" defer></script>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/header.ejs') %>

        <!-- ============================== -->
        <!-- MAIN CONTENT -->
        <!-- ============================== -->
        <main>

            <!-- ============================== -->
            <!-- SECTION: FAQ Search -->
            <!-- ============================== -->
            <section class="faq-search">
                <input type="text" placeholder="جستجو در سوالات">
                <button>جستجو</button>
            </section>

            <!-- ============================== -->
            <!-- SECTION: FAQ List -->
            <!-- ============================== -->
            <section class="faq">
                <h2>سوالات متداول</h2>

                <div class="faq-list">
                    <% if (data && Object.keys(data).length> 0) { %>
                        <% Object.values(data).forEach(item=> { %>
                            <div class="faq-item">
                                <div class="faq-title">
                                    <%= item.question %>
                                </div>
                                <div class="faq-content">
                                    <%= item.answer %>
                                </div>
                            </div>
                        <% }) %>
                        <% } else { %>
                            <p>هیچ سوالی یافت نشد.</p>
                        <% } %>
                </div>
            </section>

        </main>

        <!-- ============================== -->
        <!-- FOOTER: Include footer partial -->
        <!-- ============================== -->
        <%- include('./partials/footer.ejs') %>

</body>

</html>