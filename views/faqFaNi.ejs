<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>سوالات متداول</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

:root {
    --primary: #C4A97D;
    --secondary: #3A3A3A;
    --accent: #C4A97D;
    --accent-light: #A0845C;
    --bg: #1A1A1A;
    --bg-warm: #2A2A2A;
    --border: #444444;
    --text: #F0F0F0;
    --text-light: #B0B0B0;
}

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN */
        /* ============================== */
        main {
            padding: 0 5rem;
            max-width: 900px;
            margin: 0 auto;
        }

        /* ============================== */
        /* FAQ SEARCH */
        /* ============================== */
        .faq-search {
            display: flex;
            gap: 0.5rem;
            max-width: 450px;
            margin: 3rem 0 2.5rem;
        }

        .faq-search input {
            flex: 1;
            padding: 0.7rem 1rem;
            font-family: inherit;
            font-size: 0.95rem;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            transition: border-color .2s;
        }

        .faq-search input:focus {
            outline: none;
            border-color: var(--accent);
        }

        .faq-search button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.7rem 1.8rem;
            border-radius: 4px;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background .2s;
        }

        .faq-search button:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* FAQ LIST */
        /* ============================== */
        .faq h2 {
            font-size: 2rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.5rem;
        }

        .faq-list {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            margin-bottom: 4rem;
        }

        .faq-item {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 1.5rem 1.8rem;
            transition: transform .2s, box-shadow .2s;
        }

        .faq-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, .04);
        }

        .faq-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--primary);
            cursor: pointer;
            margin-bottom: 0.3rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .faq-title::after {
            content: '▼';
            font-size: 0.8rem;
            color: var(--accent);
            transition: transform .2s;
        }

        .faq-item.active .faq-title::after {
            transform: rotate(180deg);
        }

        .faq-content {
            font-size: 0.95rem;
            color: var(--text-light);
            line-height: 1.8;
            margin-top: 0.8rem;
            display: none;
        }

        .faq-item.active .faq-content {
            display: block;
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 768px) {
            main {
                padding: 0 2rem;
            }

            .faq-search {
                max-width: 100%;
                flex-direction: column;
            }

            .faq-search button {
                width: 100%;
                padding: 0.8rem;
            }

            .faq h2 {
                font-size: 1.6rem;
            }

            .faq-item {
                padding: 1rem 1.2rem;
            }

            .faq-title {
                font-size: 1rem;
            }

            .faq-content {
                font-size: 0.9rem;
            }
        }

        @media (max-width: 480px) {
            main {
                padding: 0 1.2rem;
            }

            .faq h2 {
                font-size: 1.3rem;
            }
        }
    </style>

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
    <script src="/public/faq_Script.js" defer></script>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerNi.ejs') %>

        <!-- ============================== -->
        <!-- MAIN CONTENT -->
        <!-- ============================== -->
        <main>

            <!-- ============================== -->
            <!-- SECTION: FAQ Search -->
            <!-- ============================== -->
            <section class="faq-search">
                <input type="text" placeholder="جستجو در سوالات">
                <button>جستجو</button>
            </section>

            <!-- ============================== -->
            <!-- SECTION: FAQ List -->
            <!-- ============================== -->
            <section class="faq">
                <h2>سوالات متداول</h2>

                <div class="faq-list">
                    <% if (data && Object.keys(data).length> 0) { %>
                        <% Object.values(data).forEach(item=> { %>
                            <div class="faq-item">
                                <div class="faq-title">
                                    <%= item.question %>
                                </div>
                                <div class="faq-content">
                                    <%= item.answer %>
                                </div>
                            </div>
                        <% }) %>
                        <% } else { %>
                            <p>هیچ سوالی یافت نشد.</p>
                        <% } %>
                </div>
            </section>

        </main>

        <!-- ============================== -->
        <!-- FOOTER: Include footer partial -->
        <!-- ============================== -->
        <%- include('./partials/footerNi.ejs') %>

</body>

</html>
