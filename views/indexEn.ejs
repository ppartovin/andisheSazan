<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Company Name</title>

    <!-- ============================== -->
    <!-- STYLES -->
    <!-- ============================== -->
    <link rel="stylesheet" href="/public/css/fonts.css">

    <link rel="stylesheet" href="/public/css/indexEn_style.css">
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerEn.ejs') %>

        <!-- ============================== -->
        <!-- MAIN CONTENT -->
        <!-- ============================== -->
        <main>

            <!-- Page title -->
            <h1>Page Content</h1>

            <!-- Introduction paragraph -->
            <p>Main content goes here.</p>

            <!-- ============================== -->
            <!-- SECTION 1: Top Products -->
            <!-- ============================== -->
            <section>
                <h2>Top Products</h2>

                <div class="products">
                    <% if (data.topProducts && data.topProducts.length > 0) { %>
                        <% data.topProducts.forEach(product => { %>
                            <a href="/product/<%= product.id %>/en" class="product-link">
                                <div class="product">
                                    <img src="<%= product.image[0] || 'default.jpg' %>" alt="<%= product.title %>">
                                    <h3><%= product.title %></h3>
                                    <p><%= product.subtitle || '' %></p>
                                    <span><%= product.price || '' %></span>
                                </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p>No products found.</p>
                    <% } %>
                </div>

                <div class="more">
                    <a href="/products/en">View More</a>
                </div>
            </section>

            <!-- ============================== -->
            <!-- SECTION 2: Services -->
            <!-- ============================== -->
            <section>
                <h2>What We Do</h2>

                <div class="services">
                    <div class="service">
                        <h3>Ideation</h3>
                        <p>Creating new ideas and designing game experience</p>
                    </div>

                    <div class="service">
                        <h3>Game Design</h3>
                        <p>Designing rules, cards and game structure</p>
                    </div>

                    <div class="service">
                        <h3>Prototyping</h3>
                        <p>Building prototypes with 3D printing and wood cutting</p>
                    </div>

                    <div class="service">
                        <h3>Production & Sales</h3>
                        <p>Limited production or collaboration with manufacturers</p>
                    </div>
                </div>
            </section>

            <!-- ============================== -->
            <!-- SECTION 3: Why Us -->
            <!-- ============================== -->
            <section>
                <h2>Why Us</h2>

                <div class="reasons">
                    <div class="reason">
                        <h3>Creative Design</h3>
                        <p>Focus on game experience and fresh ideas</p>
                    </div>

                    <div class="reason">
                        <h3>Rapid Prototyping</h3>
                        <p>Building prototypes with 3D printing and wood cutting</p>
                    </div>

                    <div class="reason">
                        <h3>Flexible Production</h3>
                        <p>Ability to do limited runs or work with manufacturers</p>
                    </div>

                    <div class="reason">
                        <h3>Experience Quality Focus</h3>
                        <p>Testing and improving the game before launch</p>
                    </div>
                </div>
            </section>

        </main>

        <!-- ============================== -->
        <!-- FOOTER: Include footer partial -->
        <!-- ============================== -->
        <%- include('./partials/footerEn.ejs') %>

</body>

</html>