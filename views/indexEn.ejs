<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Company Name</title>

    <!-- ============================== -->
    <!-- STYLES -->
    <!-- ============================== -->
    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN */
        /* ============================== */
        main {
            padding: 0 5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        main h1 {
            font-size: 2.8rem;
            font-weight: 600;
            color: var(--primary);
            line-height: 1.2;
            margin-top: 4rem;
            margin-bottom: 1rem;
            letter-spacing: -1px;
        }

        main>p {
            font-size: 1.1rem;
            color: var(--text-light);
            max-width: 620px;
            margin-bottom: 3rem;
        }

        /* ============================== */
        /* SECTION HEADER (shared) */
        /* ============================== */
        section {
            margin-bottom: 4rem;
        }

        section h2 {
            font-size: 2rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        /* ============================== */
        /* PRODUCTS (top products) */
        /* ============================== */
        .products {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            margin: 2rem 0 1.5rem;
        }

        .product {
            border: 1px solid var(--border);
            overflow: hidden;
            background: var(--bg);
            transition: transform .2s, box-shadow .2s;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .product:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, .04);
        }

        .product img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: var(--bg-warm);
            border-bottom: 1px solid var(--border);
        }

        .product h3 {
            font-size: 1rem;
            font-weight: 500;
            color: var(--primary);
            padding: 1rem 1.5rem 0.3rem;
            margin: 0;
        }

        .product p {
            font-size: 0.9rem;
            color: var(--text-light);
            padding: 0 1.5rem 0.5rem;
            margin: 0;
        }

        .product span {
            color: var(--accent);
            font-weight: 600;
            font-size: 1.05rem;
            padding: 0 1.5rem 1.5rem;
            display: block;
        }

        .more {
            margin: 0.5rem 0 2rem;
        }

        .more a {
            display: inline-block;
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.7rem 2rem;
            border-radius: 4px;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            text-decoration: none;
            transition: all .2s;
        }

        .more a:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* SERVICES & REASONS (same style) */
        /* ============================== */
        .services,
        .reasons {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            margin: 1.5rem 0;
        }

        .service,
        .reason {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 2rem 1.5rem;
            transition: transform .2s, box-shadow .2s;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .service:hover,
        .reason:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, .04);
        }

        .service h3,
        .reason h3 {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.3rem;
        }

        .service p,
        .reason p {
            font-size: 0.95rem;
            color: var(--text-light);
            margin: 0;
        }

        .product-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .product-link:hover .product {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, .04);
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 992px) {
            .products,
            .services,
            .reasons {
                grid-template-columns: repeat(2, 1fr);
            }
            main {
                padding: 0 2rem;
            }
            main h1 {
                font-size: 2.2rem;
            }
        }

        @media (max-width: 600px) {
            .products,
            .services,
            .reasons {
                grid-template-columns: 1fr;
            }
            main {
                padding: 0 1.2rem;
            }
            main h1 {
                font-size: 1.8rem;
                margin-top: 2rem;
            }
            main>p {
                font-size: 1rem;
            }
        }
    </style>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/header.ejs') %>

        <!-- ============================== -->
        <!-- MAIN CONTENT -->
        <!-- ============================== -->
        <main>

            <!-- Page title -->
            <h1>Page Content</h1>

            <!-- Introduction paragraph -->
            <p>Main content goes here.</p>

            <!-- ============================== -->
            <!-- SECTION 1: Top Products -->
            <!-- ============================== -->
            <section>
                <h2>Top Products</h2>

                <div class="products">
                    <% if (data.topProducts && data.topProducts.length > 0) { %>
                        <% data.topProducts.forEach(product => { %>
                            <a href="/product/<%= product.id %>/en" class="product-link">
                                <div class="product">
                                    <img src="<%= product.image[0] || 'default.jpg' %>" alt="<%= product.title %>">
                                    <h3><%= product.title %></h3>
                                    <p><%= product.subtitle || '' %></p>
                                    <span><%= product.price || '' %></span>
                                </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p>No products found.</p>
                    <% } %>
                </div>

                <div class="more">
                    <a href="/products">View More</a>
                </div>
            </section>

            <!-- ============================== -->
            <!-- SECTION 2: Services -->
            <!-- ============================== -->
            <section>
                <h2>What We Do</h2>

                <div class="services">
                    <div class="service">
                        <h3>Ideation</h3>
                        <p>Creating new ideas and designing game experience</p>
                    </div>

                    <div class="service">
                        <h3>Game Design</h3>
                        <p>Designing rules, cards and game structure</p>
                    </div>

                    <div class="service">
                        <h3>Prototyping</h3>
                        <p>Building prototypes with 3D printing and wood cutting</p>
                    </div>

                    <div class="service">
                        <h3>Production & Sales</h3>
                        <p>Limited production or collaboration with manufacturers</p>
                    </div>
                </div>
            </section>

            <!-- ============================== -->
            <!-- SECTION 3: Why Us -->
            <!-- ============================== -->
            <section>
                <h2>Why Us</h2>

                <div class="reasons">
                    <div class="reason">
                        <h3>Creative Design</h3>
                        <p>Focus on game experience and fresh ideas</p>
                    </div>

                    <div class="reason">
                        <h3>Rapid Prototyping</h3>
                        <p>Building prototypes with 3D printing and wood cutting</p>
                    </div>

                    <div class="reason">
                        <h3>Flexible Production</h3>
                        <p>Ability to do limited runs or work with manufacturers</p>
                    </div>

                    <div class="reason">
                        <h3>Experience Quality Focus</h3>
                        <p>Testing and improving the game before launch</p>
                    </div>
                </div>
            </section>

        </main>

        <!-- ============================== -->
        <!-- FOOTER: Include footer partial -->
        <!-- ============================== -->
        <%- include('./partials/footer.ejs') %>

</body>

</html>