<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<title><%= data.title %></title>
</head>

<style>
.shops{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.shop{
  display:flex;
  align-items:center;
  gap:8px;
  text-decoration:none;
  color:inherit;
}

.shop img{
  width:24px;
  height:24px;
}
</style>

<body>

<%- include('./partials/header.ejs') %>

<main>

<section class="product-gallery">

<button id="prev">←</button>

<img id="product-image" src="<%= data.image[0] %>" alt="product">

<button id="next">→</button>

</section>


<section class="product-header">

<h1 class="product-title"><%= data.title %></h1>
<p class="product-subtitle"><%= data.subtitle %></p>

</section>


<section class="product-shops">

<div class="shops">

<% data.shops.forEach(shop => { %>

<a class="shop" href="<%= shop.link %>" target="_blank">
  <img src="<%= shop.image %>" alt="">
  <span><%= shop.name %></span>
</a>

<% }) %>

</div>

</section>


<section class="product-description">

<h2>توضیحات</h2>

<p id="short-desc">
<%= data.description %>
</p>

<div id="full-desc" style="display:none;">
<p><%= data.description %></p>
</div>

<button id="more">بیشتر</button>
<button id="less" style="display:none;">کمتر</button>

</section>


<section class="product-features">

<h2>ویژگی‌ها</h2>

<table>

<tr>
<th>ویژگی</th>
<th>توضیح</th>
</tr>

<% Object.entries(data.properties).forEach(([key,value]) => { %>

<tr>
<td><%= key %></td>
<td><%= value %></td>
</tr>

<% }) %>

</table>

</section>

</main>

<%- include('./partials/footer.ejs') %>


<script>

const images = <%- JSON.stringify(data.image) %>

let index = 0

const img = document.getElementById("product-image")

document.getElementById("next").onclick = () => {
  index++
  if(index >= images.length) index = 0
  img.src = images[index]
}

document.getElementById("prev").onclick = () => {
  index--
  if(index < 0) index = images.length - 1
  img.src = images[index]
}


const more = document.getElementById("more")
const less = document.getElementById("less")
const shortDesc = document.getElementById("short-desc")
const fullDesc = document.getElementById("full-desc")

more.onclick = () => {
  shortDesc.style.display = "none"
  fullDesc.style.display = "block"
  more.style.display = "none"
  less.style.display = "inline"
}

less.onclick = () => {
  shortDesc.style.display = "block"
  fullDesc.style.display = "none"
  more.style.display = "inline"
  less.style.display = "none"
}

</script>

</body>
</html>
