<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.title %></title>

    <!-- ============================== -->
    <!-- STYLES -->
    <!-- ============================== -->
    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>
        :root {
            --primary: #1F1F1F;
            --secondary: #3A3A3A;
            --accent: #A0845C;
            --accent-light: #C4A97D;
            --bg: #FAFAF8;
            --bg-warm: #F5F3EF;
            --border: #E8E6E1;
            --text: #2D2D2D;
            --text-light: #787878;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        main {
            padding: 0 5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .product-gallery {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 2rem;
            margin: 3rem 0 2rem;
        }

        .product-gallery button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.7rem 1.2rem;
            border-radius: 4px;
            font-family: inherit;
            font-size: 1.2rem;
            cursor: pointer;
            transition: background .2s;
        }

        .product-gallery button:hover {
            background: var(--accent);
        }

        #product-image {
            width: 100%;
            max-width: 500px;
            aspect-ratio: 1;
            object-fit: cover;
            background: var(--bg-warm);
            border: 1px solid var(--border);
            border-radius: 0;
        }

        .product-header {
            text-align: center;
            margin: 2rem 0 2.5rem;
            border-bottom: 1px solid var(--border);
            padding-bottom: 2rem;
        }

        .product-title {
            font-size: 2.5rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.3rem;
        }

        .product-subtitle {
            font-size: 1.1rem;
            color: var(--text-light);
        }

        .product-shops {
            margin: 2rem 0;
        }

        .shops {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
        }

        .shop {
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--text);
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 0.5rem 1.2rem;
            transition: background .2s, transform .2s;
        }

        .shop:hover {
            background: var(--bg-warm);
            transform: translateY(-3px);
        }

        .shop img {
            width: 28px;
            height: 28px;
            object-fit: contain;
        }

        .shop span {
            font-size: 0.95rem;
            font-weight: 500;
        }

        .product-description {
            margin: 2.5rem 0;
        }

        .product-description h2 {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 1rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.5rem;
        }

        .description-wrapper {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 2rem;
        }

        #short-desc,
        #full-desc p {
            font-size: 1rem;
            color: var(--text);
            line-height: 1.8;
            margin: 0;
        }

        #full-desc {
            display: none;
        }

        #more,
        #less {
            margin-top: 1rem;
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.6rem 1.8rem;
            border-radius: 4px;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background .2s;
        }

        #more:hover,
        #less:hover {
            background: var(--accent);
        }

        #less {
            display: none;
        }

        .product-features {
            margin: 2.5rem 0 4rem;
        }

        .product-features h2 {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 1rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.5rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--bg);
            border: 1px solid var(--border);
        }

        th,
        td {
            padding: 0.8rem 1.2rem;
            text-align: right;
            border-bottom: 1px solid var(--border);
        }

        th {
            background: var(--bg-warm);
            font-weight: 600;
            color: var(--primary);
        }

        td {
            color: var(--text);
        }

        tr:last-child td {
            border-bottom: none;
        }

        @media (max-width: 768px) {
            main {
                padding: 0 2rem;
            }
            .product-title {
                font-size: 2rem;
            }
            .product-gallery {
                flex-direction: row;
                gap: 1rem;
            }
            #product-image {
                max-width: 280px;
            }
            .shops {
                gap: 0.6rem;
            }
            .shop {
                padding: 0.4rem 0.8rem;
            }
            .description-wrapper {
                padding: 1.2rem;
            }
            table {
                font-size: 0.9rem;
            }
            th,
            td {
                padding: 0.5rem 0.8rem;
            }
        }

        @media (max-width: 480px) {
            main {
                padding: 0 1rem;
            }
            .product-title {
                font-size: 1.5rem;
            }
            .product-gallery {
                flex-wrap: wrap;
                gap: 0.8rem;
            }
            .product-gallery button {
                padding: 0.4rem 0.8rem;
                font-size: 1rem;
            }
            #product-image {
                max-width: 200px;
            }
            .shops {
                flex-direction: column;
                align-items: center;
            }
            .shop {
                width: 100%;
                justify-content: center;
            }
            .description-wrapper {
                padding: 0.8rem;
            }
            #short-desc,
            #full-desc p {
                font-size: 0.9rem;
            }
        }
    </style>

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
<script src="/public/product_Script.js" defer data-images='<%= JSON.stringify(data.image) %>'></script>
</head>

<body>

    <%- include('./partials/header.ejs') %>

    <main>

        <section class="product-gallery">
            <button id="prev">←</button>
            <img id="product-image" src="<%= data.image[0] %>" alt="product">
            <button id="next">→</button>
        </section>

        <section class="product-header">
            <h1 class="product-title"><%= data.title %></h1>
            <p class="product-subtitle"><%= data.subtitle %></p>
        </section>

        <section class="product-shops">
            <div class="shops">
                <% data.shops.forEach(shop => { %>
                    <a class="shop" href="<%= shop.link %>" target="_blank">
                        <img src="<%= shop.image %>" alt="">
                        <span><%= shop.name %></span>
                    </a>
                <% }) %>
            </div>
        </section>

        <section class="product-description">
            <h2>توضیحات</h2>
            <div class="description-wrapper">
                <p id="short-desc">
                    <%= data.description.substring(0, 150) + (data.description.length > 150 ? '...' : '') %>
                </p>
                <div id="full-desc">
                    <p><%= data.description %></p>
                </div>
                <% if (data.description.length > 150) { %>
                    <button id="more">بیشتر ▼</button>
                    <button id="less" style="display:none;">کمتر ▲</button>
                <% } %>
            </div>
        </section>

        <section class="product-features">
            <h2>ویژگی‌ها</h2>
            <table>
                <tr>
                    <th>ویژگی</th>
                    <th>توضیح</th>
                </tr>
                <% Object.entries(data.properties).forEach(([key, value]) => { %>
                    <tr>
                        <td><%= key %></td>
                        <td><%= value %></td>
                    </tr>
                <% }) %>
            </table>
        </section>

    </main>

    <%- include('./partials/footer.ejs') %>

</body>
</html>