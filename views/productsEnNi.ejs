<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products List</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <style>

		:root {
			--primary: #C4A97D;
			--secondary: #3A3A3A;
			--accent: #C4A97D;
			--accent-light: #A0845C;
			--bg: #1A1A1A;
			--bg-warm: #2A2A2A;
			--border: #444444;
			--text: #F0F0F0;
			--text-light: #B0B0B0;
		}

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
        }

        /* ============================== */
        /* MAIN */
        /* ============================== */
        main {
            padding: 0 5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        main h1 {
            font-size: 2.8rem;
            font-weight: 600;
            color: var(--primary);
            line-height: 1.2;
            margin-top: 3rem;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
        }

        /* ============================== */
        /* SEARCH SECTION */
        /* ============================== */
        .product-search {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 2.5rem;
            max-width: 500px;
        }

        .product-search input {
            flex: 1;
            padding: 0.7rem 1rem;
            font-family: inherit;
            font-size: 0.95rem;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            transition: border-color .2s;
        }

        .product-search input:focus {
            outline: none;
            border-color: var(--accent);
        }

        .product-search input::placeholder {
            color: var(--text-light);
        }

        .product-search button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.7rem 1.8rem;
            border-radius: 4px;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background .2s;
        }

        .product-search button:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* PRODUCT LIST CONTAINER */
        /* ============================== */
        #product-list-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin: 2rem 0 1.5rem;
        }

        .product-item {
            border: 1px solid var(--border);
            overflow: hidden;
            background: var(--bg);
            transition: transform .2s, box-shadow .2s;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .product-item:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, .04);
        }

        .product-item h3 {
            font-size: 1rem;
            font-weight: 500;
            color: var(--primary);
            margin-bottom: 0.3rem;
        }

        .product-item p {
            font-size: 0.9rem;
            color: var(--text-light);
            margin-bottom: 0.5rem;
            flex: 1;
        }

        .product-item span {
            color: var(--accent);
            font-weight: 600;
            font-size: 1rem;
            display: block;
            margin-bottom: 0.5rem;
        }

        .product-item a {
            display: inline-block;
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.4rem 1.2rem;
            font-family: inherit;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            cursor: pointer;
            transition: background .2s;
            margin-top: auto;
            align-self: flex-start;
            border-radius: 4px;
        }

        .product-item a:hover {
            background: var(--accent);
        }

        /* ============================== */
        /* INFINITE SCROLL ANCHOR */
        /* ============================== */
        #infinite-scroll-anchor {
            text-align: center;
            padding: 2rem 0;
            color: var(--text-light);
            font-size: 0.95rem;
        }

        /* ============================== */
        /* RESPONSIVE */
        /* ============================== */
        @media (max-width: 992px) {
            main {
                padding: 0 2rem;
            }

            main h1 {
                font-size: 2.2rem;
                margin-top: 2rem;
            }

            #product-list-container {
                grid-template-columns: repeat(2, 1fr);
                gap: 1.5rem;
            }
        }

        @media (max-width: 600px) {
            main {
                padding: 0 1.2rem;
            }

            main h1 {
                font-size: 1.8rem;
                margin-top: 1.5rem;
            }

            #product-list-container {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .product-search {
                flex-direction: column;
                max-width: 100%;
            }

            .product-search button {
                width: 100%;
                padding: 0.8rem;
            }
        }
    </style>

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
    <script src="/public/products_Script.js" defer></script>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/headerEnNi.ejs') %>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- Page title -->
        <h1>Products List</h1>

        <!-- ============================== -->
        <!-- SEARCH SECTION -->
        <!-- ============================== -->
        <div class="product-search">
            <input type="text" id="searchInput" placeholder="Search products..." />
            <button id="searchBtn">Search</button>
        </div>

        <!-- ============================== -->
        <!-- PRODUCT LIST CONTAINER -->
        <!-- ============================== -->
        <section id="product-list-container">
            <!-- Products will be injected here -->
        </section>

        <!-- ============================== -->
        <!-- INFINITE SCROLL ANCHOR -->
        <!-- ============================== -->
        <div id="infinite-scroll-anchor">
            <p>Loading products...</p>
        </div>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footerEnNi.ejs') %>

</body>
</html>