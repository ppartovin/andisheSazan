<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لیست محصولات</title>

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
    <script src="/public/products_Script.js" defer></script>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/header.ejs') %>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- Page title -->
        <h1>لیست محصولات</h1>

        <!-- ============================== -->
        <!-- SIDEBAR: Filters Section -->
        <!-- ============================== -->
        <aside>
            <h2>فیلترها</h2>
            <ul>
                <li>دسته‌بندی ۱</li>
                <li>دسته‌بندی ۲</li>
                <li>دسته‌بندی ۳</li>
            </ul>
        </aside>

        <!-- ============================== -->
        <!-- PRODUCT LIST CONTAINER -->
        <!-- ============================== -->
        <!-- All products will be loaded here dynamically by JavaScript (Infinite Scroll) -->
        <section id="product-list-container">
            <!-- Products will be injected here -->
        </section>

        <!-- ============================== -->
        <!-- INFINITE SCROLL ANCHOR -->
        <!-- ============================== -->
        <!-- This element triggers loading more products when scrolled into view -->
        <div id="infinite-scroll-anchor">
            <p>در حال بارگذاری محصولات...</p>
        </div>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footer.ejs') %>

</body>
</html>