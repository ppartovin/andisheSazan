<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لیست محصولات</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <link rel="stylesheet" href="/public/css/productsFa_style.css">

    <!-- ============================== -->
    <!-- EXTERNAL SCRIPTS - Deferred -->
    <!-- ============================== -->
    <script src="/public/products_Script.js" defer></script>
</head>

<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/header.ejs') %>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- Page title -->
        <h1>لیست محصولات</h1>

        <!-- ============================== -->
        <!-- SEARCH SECTION -->
        <!-- ============================== -->
        <div class="product-search">
            <input type="text" id="searchInput" placeholder="جستجو در محصولات..." />
            <button id="searchBtn">جستجو</button>
        </div>

        <!-- ============================== -->
        <!-- PRODUCT LIST CONTAINER -->
        <!-- ============================== -->
        <section id="product-list-container">
            <!-- Products will be injected here -->
        </section>

        <!-- ============================== -->
        <!-- INFINITE SCROLL ANCHOR -->
        <!-- ============================== -->
        <div id="infinite-scroll-anchor">
            <p>در حال بارگذاری محصولات...</p>
        </div>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footer.ejs') %>

</body>
</html>
