<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خرید عمده و سازمانی</title>

    <link rel="stylesheet" href="/public/css/fonts.css">

    <link rel="stylesheet" href="/public/css/wholesaleFa_style.css">

</head>
<body>

    <!-- ============================== -->
    <!-- HEADER: Include header partial -->
    <!-- ============================== -->
    <%- include('./partials/header.ejs') %>

    <!-- ============================== -->
    <!-- MAIN CONTENT -->
    <!-- ============================== -->
    <main>

        <!-- Page title -->
        <h1>خرید عمده و تأمین کالا</h1>

        <!-- Introduction paragraph -->
        <p>
            مجموعه ما آماده همکاری با فروشگاه‌ها، سازمان‌ها و بازرگانان جهت تأمین کالا در حجم بالا با شرایط رقابتی است.
        </p>

        <!-- ============================== -->
        <!-- SECTION 1: Benefits -->
        <!-- ============================== -->
        <section>
            <h2>مزایای خرید عمده از ما</h2>
            <ul>
                <li>قیمت‌گذاری پلکانی (تخفیف بیشتر در حجم بالاتر)</li>
                <li>تضمین اصالت و کیفیت کالا</li>
                <li>ارسال سریع و باربری اختصاصی</li>
                <li>امکان صدور فاکتور رسمی (ارزش افزوده)</li>
            </ul>
        </section>

        <!-- ============================== -->
        <!-- SECTION 2: Product Categories -->
        <!-- ============================== -->
        <section>
            <h2>دسته‌بندی محصولات عمده</h2>
            <ul>
                <li><strong>دسته اول:</strong> توضیحات مختصر درباره تنوع این دسته</li>
                <li><strong>دسته دوم:</strong> توضیحات مختصر درباره تنوع این دسته</li>
                <li><strong>دسته سوم:</strong> توضیحات مختصر درباره تنوع این دسته</li>
            </ul>
        </section>

        <!-- ============================== -->
        <!-- SECTION 3: Order Process -->
        <!-- ============================== -->
        <section>
            <h2>فرآیند ثبت سفارش عمده</h2>
            <ol>
                <li>ثبت فرم استعلام توسط مشتری</li>
                <li>تماس کارشناسان فروش و ارائه پیش‌فاکتور</li>
                <li>تأیید نهایی و واریز وجه</li>
                <li>ارسال بار و تحویل در محل</li>
            </ol>
        </section>

        <!-- ============================== -->
        <!-- SECTION 4: Contact Information -->
        <!-- ============================== -->
        <section>
            <h2>اطلاعات تماس مستقیم</h2>
            <div class="contact-info">
                <div class="contact-item">
                    <strong>شماره مستقیم واحد فروش عمده:</strong>
                    <span>+98 21 0000 0000</span>
                </div>
                <div class="contact-item">
                    <strong>واتس‌اپ / تلگرام واحد فروش:</strong>
                    <span>+98 900 000 0000</span>
                </div>
                <div class="contact-item">
                    <strong>آدرس دفتر مرکزی</strong>
                    <span>تهران، ایران</span>
                </div>
            </div>
        </section>

    </main>

    <!-- ============================== -->
    <!-- FOOTER: Include footer partial -->
    <!-- ============================== -->
    <%- include('./partials/footer.ejs') %>

</body>
</html>
